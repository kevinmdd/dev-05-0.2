<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.application.HomePageController"
      alignment="CENTER"
      spacing="25">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="FlashMaster"
           style="-fx-font-size: 32px; -fx-font-weight: bold;" />

    <Label text="Home Page"
           style="-fx-font-size: 18px;" />

    <Button text="Create New Deck"
            prefWidth="220"
            onAction="#handleCreateDeck"/>

    <Button text="View Existing Decks"
            prefWidth="220"
            onAction="#handleViewDecks"/>

    <Button text="Create Flashcard"
            onAction="#handleCreateFlashcard" />

    <Button text="View Flashcards"
            onAction="#handleViewFlashcards" />

    <Button text="Search Flashcards"
            onAction="#handleSearchFlashcards" />

</VBox>